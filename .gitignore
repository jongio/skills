# Dependencies are vendored — there is no install step and no node_modules.
node_modules/
dist/
build/

# Optional dev tooling (the Vally eval) pulls dev deps + writes results.
# Shipped canvases stay dependency-free; these are skill-repo dev artifacts only.
package-lock.json
vally-results/

# Local canvas state written by the reference extension / generated canvases.
artifacts/

# Generated report output (re-generate with `node scripts/generate-html-report.mjs`)
*-report.html

# OS / editor noise
.DS_Store
Thumbs.db
*.log
