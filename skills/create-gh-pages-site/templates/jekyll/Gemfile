source "https://rubygems.org"

# Jekyll for local development (`bundle exec jekyll serve`).
# CI builds with the official actions/jekyll-build-pages action.
gem "jekyll", "~> 4.3"

# Windows and JRuby do not include zoneinfo files, so bundle the tzinfo-data gem.
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end
