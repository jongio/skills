---
interface Props {
  title?: string;
  description?: string;
}
const { title = "__SITE_NAME__", description = "An Astro site on GitHub Pages." } = Astro.props;

// `base` already ends in a slash (e.g. "/repo/" or "/"), so concatenating a
// bare path produces a correct, base-aware URL.
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #0d1117; --panel: #161b22; --border: #30363d;
        --fg: #e6edf3; --muted: #9198a1; --accent: #2f81f7;
      }
      @media (prefers-color-scheme: light) {
        :root {
          --bg: #fff; --panel: #f6f8fa; --border: #d0d7de;
          --fg: #1f2328; --muted: #59636e; --accent: #0969da;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--fg);
        font: 16px/1.6 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      }
      a { color: var(--accent); }
      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9em;
        background: color-mix(in srgb, var(--accent) 12%, transparent);
        padding: 0.1em 0.4em; border-radius: 6px;
      }
      .wrap { max-width: 880px; margin: 0 auto; padding: clamp(2rem, 6vw, 5rem) 1.25rem; }
      nav { display: flex; gap: 1.25rem; justify-content: center; margin-bottom: 2.5rem; }
      nav a { text-decoration: none; font-weight: 600; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <nav>
        <a href={base}>Home</a>
        <a href={`${base}about/`}>About</a>
      </nav>
      <slot />
    </div>
  </body>
</html>
