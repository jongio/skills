---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About · __SITE_NAME__" description="About this Astro template.">
  <header style="text-align:center;">
    <h1 style="font-size:clamp(1.75rem,5vw,2.5rem);margin:0 0 .75rem;">About</h1>
  </header>
  <section class="card">
    <h2>What this template demonstrates</h2>
    <ul>
      <li><strong>Islands</strong> — a hydrated Preact component (the home-page counter).</li>
      <li><strong>Content collections</strong> — typed Markdown driving the Blog.</li>
      <li><strong>View transitions</strong> — <code>&lt;ClientRouter /&gt;</code> animates navigation.</li>
      <li><strong>Theming</strong> — a persisted light/dark toggle that survives transitions.</li>
      <li><strong>Base path</strong> — <code>site</code> + <code>base</code> wired for GitHub Pages; links use <code>import.meta.env.BASE_URL</code>.</li>
    </ul>
    <p class="muted">Source: <a href="https://github.com/__REPO_SLUG__">github.com/__REPO_SLUG__</a></p>
  </section>
</Layout>
