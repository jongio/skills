---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<article style="background: var(--panel); border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem;">
  <h2 style="margin: 0 0 0.4rem; font-size: 1.1rem;">{title}</h2>
  <p style="margin: 0; color: var(--muted);"><slot /></p>
</article>
