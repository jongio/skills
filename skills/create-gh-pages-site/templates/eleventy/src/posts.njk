---
layout: base.njk
title: Posts · __SITE_NAME__
---
<section class="prose">
  <h1>Posts</h1>
  <ul class="posts">
    {%- for post in collections.posts | reverse %}
    <li>
      <a href="{{ post.url | url }}">{{ post.data.title }}</a>
      <time>{{ post.date | date }}</time>
    </li>
    {%- endfor %}
  </ul>
</section>
