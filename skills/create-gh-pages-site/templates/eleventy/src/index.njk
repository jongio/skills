---
layout: base.njk
title: __SITE_NAME__
---
<header class="hero">
  <p class="eyebrow">GitHub Pages · Eleventy</p>
  <h1>__SITE_NAME__</h1>
  <p class="lede">
    A data-driven static site, and a reference for Eleventy's building blocks:
    data files, filters, shortcodes, collections, and pagination.
  </p>
</header>

{% note %}
  This callout is rendered by a <strong>paired shortcode</strong> defined in
  <code>eleventy.config.js</code>. The nav above is built from a
  <code>_data/nav.json</code> data file.
{% endnote %}

<section class="grid">
  <article class="card">
    <h2>Data files</h2>
    <p class="muted"><code>_data/</code> JSON/JS drives content — like the nav above.</p>
  </article>
  <article class="card">
    <h2>Filters &amp; shortcodes</h2>
    <p class="muted"><code>readableDate</code>, <code>head</code>, <code>{% raw %}{% year %}{% endraw %}</code>, and <code>note</code>.</p>
  </article>
  <article class="card">
    <h2>Pagination</h2>
    <p class="muted">The <a href="{{ '/posts/' | url }}">Posts</a> page paginates the collection.</p>
  </article>
</section>

<section class="card">
  <h2>Latest posts</h2>
  <ul class="posts">
    {%- for post in collections.posts | reverse | head(2) %}
    <li>
      <a href="{{ post.url | url }}">{{ post.data.title }}</a>
      <time>{{ post.date | readableDate }}</time>
    </li>
    {%- endfor %}
  </ul>
</section>
