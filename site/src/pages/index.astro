---
import Layout from "../layouts/Layout.astro";
import Counter from "../components/Counter.jsx";
const base = import.meta.env.BASE_URL;
---

<Layout title="Skills">
  <header style="text-align:center;margin-bottom:2rem;">
    <p style="text-transform:uppercase;letter-spacing:.08em;font-size:.78rem;font-weight:600;color:var(--muted);margin:0 0 .5rem;">
      GitHub Pages · Astro
    </p>
    <h1 style="font-size:clamp(2rem,6vw,3rem);line-height:1.1;margin:0 0 .75rem;">Skills</h1>
    <p class="muted" style="font-size:1.12rem;max-width:46ch;margin:0 auto;">
      A statically-rendered Astro site — and a reference for the framework's
      signature features: islands, content collections, and view transitions.
    </p>
  </header>

  <section class="card">
    <h2>Islands</h2>
    <p class="muted">
      This counter is a Preact component hydrated with <code>client:visible</code>.
      Its JavaScript loads only when it scrolls into view; the rest of the page is
      static HTML.
    </p>
    <Counter client:visible start={3} />
  </section>

  <section class="card">
    <h2>What else this template shows</h2>
    <ul>
      <li><strong>Content collections</strong> — typed Markdown in the <a href={`${base}blog/`}>Blog</a>.</li>
      <li><strong>View transitions</strong> — animated navigation (click around the nav).</li>
      <li><strong>Light/dark theme</strong> + a <strong>GitHub source link</strong> in the top bar.</li>
      <li><strong>Scoped + global styles</strong> and a base-path-aware layout.</li>
    </ul>
  </section>
</Layout>
