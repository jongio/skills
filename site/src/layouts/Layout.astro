---
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}
const { title = "jongio/skills", description = "Jon Gallant's collection of cross-agent skills for AI coding agents — GitHub Copilot, Claude, and Codex." } = Astro.props;
const base = import.meta.env.BASE_URL;
const repo = "jongio/skills";
const ogImage = new URL(`${base}images/og.svg`, Astro.site ?? "https://jongio.github.io");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <!-- No-flash theme, before first paint. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme") ||
            (matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>
    <ClientRouter />
    <style is:global>
      :root {
        --bg: #0d1117; --panel: #161b22; --border: #30363d;
        --fg: #e6edf3; --muted: #9198a1; --accent: #2f81f7;
        --radius: 12px;
      }
      :root[data-theme="light"] {
        --bg: #fff; --panel: #f6f8fa; --border: #d0d7de;
        --fg: #1f2328; --muted: #59636e; --accent: #0969da;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--fg);
        font: 16px/1.6 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        transition: background 0.2s, color 0.2s;
      }
      a { color: var(--accent); }
      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9em;
        background: color-mix(in srgb, var(--accent) 12%, transparent);
        padding: 0.1em 0.4em; border-radius: 6px;
      }
      .topbar {
        display: flex; align-items: center; gap: 1rem;
        padding: 0.6rem clamp(1rem, 4vw, 2rem); border-bottom: 1px solid var(--border);
        position: sticky; top: 0; z-index: 10;
        background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(8px);
      }
      .brand { font-weight: 700; text-decoration: none; color: var(--fg); }
      .topnav { display: flex; gap: 1rem; margin-left: 0.5rem; }
      .topnav a { color: var(--muted); text-decoration: none; font-weight: 500; }
      .bar-actions { margin-left: auto; display: flex; gap: 0.4rem; align-items: center; }
      .icon-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; border-radius: 9px; border: 1px solid var(--border);
        background: var(--panel); color: var(--fg); cursor: pointer; text-decoration: none;
      }
      .icon-btn:hover { border-color: var(--accent); }
      .wrap { max-width: 760px; margin: 0 auto; padding: clamp(1.5rem, 5vw, 3.5rem) 1.25rem; }
      .card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem 1.4rem; margin: 1rem 0; }
      .card h2 { margin: 0 0 0.5rem; font-size: 1.2rem; }
      .muted { color: var(--muted); }
      .btn { display: inline-block; padding: 0.55rem 1.05rem; border-radius: 9px; background: var(--accent); color: #fff; border: 1px solid transparent; font: inherit; font-weight: 600; cursor: pointer; text-decoration: none; }
      ul.posts { list-style: none; padding: 0; }
      ul.posts li { display: flex; justify-content: space-between; gap: 1rem; padding: 0.6rem 0; border-bottom: 1px solid var(--border); }
      .codeblock { position: relative; }
      .copy-btn {
        position: absolute; top: 0.4rem; right: 0.4rem;
        font: 600 0.72rem/1 ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
        padding: 0.3rem 0.55rem; border-radius: 6px;
        border: 1px solid var(--border); background: var(--bg); color: var(--muted);
        cursor: pointer; transition: color 0.15s, border-color 0.15s, background 0.15s;
      }
      .copy-btn:hover { color: var(--fg); border-color: var(--accent); }
      .copy-btn.copied { color: #fff; background: var(--accent); border-color: var(--accent); }
      @media (prefers-reduced-motion: reduce) { body { transition: none; } }
    </style>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={base}>jongio/skills</a>
      <nav class="topnav">
        <a href={base}>Home</a>
        <a href={`${base}catalog/`}>Skills</a>
        <a href={`${base}about/`}>About</a>
      </nav>
      <div class="bar-actions">
        <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle color theme" title="Toggle theme"></button>
        <a class="icon-btn" href={`https://github.com/${repo}`} target="_blank" rel="noopener" aria-label="View source on GitHub" title="View source on GitHub">
          <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
      </div>
    </header>
    <main class="wrap"><slot /></main>

    <script>
      const SUN = '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>';
      const MOON = '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
      const root = document.documentElement;
      function applyStored() {
        try {
          const t = localStorage.getItem("theme") ||
            (matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
          root.setAttribute("data-theme", t);
        } catch (e) {}
      }
      function renderIcon() {
        const b = document.getElementById("theme-toggle");
        if (b) b.innerHTML = root.getAttribute("data-theme") === "dark" ? SUN : MOON;
      }
      document.addEventListener("click", (e) => {
        const el = e.target;
        if (!(el instanceof Element) || !el.closest("#theme-toggle")) return;
        const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
        root.setAttribute("data-theme", next);
        try { localStorage.setItem("theme", next); } catch (err) {}
        renderIcon();
      });
      // Keep theme + icon correct across Astro view transitions.
      document.addEventListener("astro:after-swap", applyStored);
      document.addEventListener("astro:page-load", renderIcon);
      renderIcon();
    </script>

    <script>
      // Add a "Copy" button to every authored code block.
      function enhanceCopy() {
        const blocks = document.querySelectorAll(".card pre, .prose pre, .skill-install pre");
        blocks.forEach((pre) => {
          if (pre.dataset.copyReady) return;
          const code = pre.querySelector("code");
          if (!code) return;
          pre.dataset.copyReady = "1";

          const wrap = document.createElement("div");
          wrap.className = "codeblock";
          pre.parentNode.insertBefore(wrap, pre);
          wrap.appendChild(pre);
          // Wrap long lines and reserve room so the button never covers code.
          pre.style.whiteSpace = "pre-wrap";
          pre.style.overflowWrap = "anywhere";
          pre.style.paddingRight = "3.6rem";

          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "copy-btn";
          btn.textContent = "Copy";
          btn.setAttribute("aria-label", "Copy to clipboard");
          btn.addEventListener("click", async () => {
            const text = code.innerText.replace(/\n$/, "");
            try {
              await navigator.clipboard.writeText(text);
            } catch (e) {
              const r = document.createRange();
              r.selectNodeContents(code);
              const sel = window.getSelection();
              sel.removeAllRanges();
              sel.addRange(r);
              try { document.execCommand("copy"); } catch (err) {}
              sel.removeAllRanges();
            }
            btn.textContent = "Copied";
            btn.classList.add("copied");
            setTimeout(() => { btn.textContent = "Copy"; btn.classList.remove("copied"); }, 1600);
          });
          wrap.appendChild(btn);
        });
      }
      document.addEventListener("astro:page-load", enhanceCopy);
    </script>
  </body>
</html>
